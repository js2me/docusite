{
  "name": "docusite",
  "version": "0.1.4",
  "description": "Dead-simple documentation tool powered by VitePress",
  "type": "module",
  "bin": {
    "docusite": "./bin/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/shared/types.d.ts",
      "import": "./dist/shared/types.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:playground": "pnpm i && cd playground && pnpm docs:dev",
    "docs:dev": "./bin/cli.mjs dev",
    "docs:build": "./bin/cli.mjs build",
    "docs:preview": "./bin/cli.mjs preview",
    "version-packages": "pnpm exec changeset version && pnpm install --lockfile-only"
  },
  "keywords": [
    "documentation",
    "vitepress",
    "docs",
    "i18n",
    "llms"
  ],
  "author": "js2me",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/js2me/docusite/issues"
  },
  "homepage": "https://github.com/js2me/docusite",
  "repository": {
    "type": "git",
    "url": "https://github.com/js2me/docusite"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@iconify-json/logos": "^1.2.11",
    "cac": "^6.7.14",
    "jiti": "^2.4.2",
    "unocss": "^66.6.7",
    "vitepress": "^1.6.3",
    "vitepress-plugin-llms": "^1.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "sborshik": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
